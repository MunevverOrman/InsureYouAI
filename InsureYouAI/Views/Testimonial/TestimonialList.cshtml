@model List<Testimonial>
@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="card shadow-sm rounded-4">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <h5 class="mb-0 fw-bold">Referanslar Sayfası</h5>

            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3">
                    <i class="bi bi-search"></i>
                </div>
                <input class="form-control ps-5 rounded-pill" type="text" placeholder="Aranacak kelimeler...">
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Ad Soyad</th>
                        <th>Unvan</th>
                        <th>Yorum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td>@count</td>
                            <td>@item.NameSurname</td>
                            <td>@item.Title</td>
                            <td>@item.CommentDetail</td>
                            <td>
                                <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId"
                                   class="text-warning"
                                   data-bs-toggle="tooltip"
                                   data-bs-placement="bottom"
                                   title="Düzenle">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                            </td>
                            <td>
                                <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId"
                                   class="text-danger"
                                   data-bs-toggle="tooltip"
                                   data-bs-placement="bottom"
                                   title="Sil">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <a href="/Testimonial/CreateTestimonial/" class="btn btn-info">
                Yeni Referans Girişi
            </a>
        </div>
    </div>
</div>

